# ==================================
# CONFIGURAÇÕES GERAIS
# ==================================

# Ambiente (development, production, test)
NODE_ENV=development

# Porta do servidor
PORT=4000

# ==================================
# BANCO DE DADOS
# ==================================

# URL de conexão do PostgreSQL
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:125312@localhost:5432/opinapp_db

# ==================================
# JWT (JSON Web Token)
# ==================================

# Segredo para assinar tokens JWT (use uma string aleatória e segura)
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=sua_chave_secreta_aqui_32_caracteres_minimo

# Tempo de expiração do token (ex: 7d, 24h, 60m)
JWT_EXPIRES_IN=7d

# ==================================
# EMAIL (SMTP)
# ==================================

# Configurações do servidor SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASS=sua_senha_ou_app_password

# Remetente padrão dos emails
EMAIL_FROM=noreply@opinapp.com
EMAIL_FROM_NAME=OpinApp

# ==================================
# FRONTEND URL
# ==================================

# URL do frontend para links em emails
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ==================================
# SEGURANÇA
# ==================================

# Pepper adicional para hash de tokens de reset (opcional mas recomendado)
TOKEN_PEPPER=outro_segredo_aleatorio_aqui

# ==================================
# LOGGING
# ==================================

# Nível de log (error, warn, info, http, verbose, debug, silly)
LOG_LEVEL=info

# ==================================
# RATE LIMITING
# ==================================

# Número máximo de requisições por janela de tempo
RATE_LIMIT_MAX=100

# Janela de tempo em minutos
RATE_LIMIT_WINDOW_MS=15

# ==================================
# RECAPTCHA (opcional - para formulários públicos)
# ==================================

# RECAPTCHA_SECRET_KEY=sua_chave_secreta_recaptcha
